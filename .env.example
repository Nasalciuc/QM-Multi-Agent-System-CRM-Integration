# =============================================================================
# Environment Variables — copy to .env and fill in values
# =============================================================================

# --- Required ---
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

# --- Optional: Direct OpenAI fallback ---
OPENAI_API_KEY=

# --- Optional: Anthropic direct fallback ---
ANTHROPIC_API_KEY=

# --- CRM API (for --date-from mode) ---
CRM_AI_TOKEN=

# --- Optional: CRM SSL verification ---
# Path to a CA bundle file for CRM API SSL verification.
# Defaults to system CA store when unset (HIGH-01).
CRM_CA_BUNDLE=

# --- Optional: Webhook for Agent 4 results ---
WEBHOOK_URL=
# HMAC-SHA256 secret for webhook payload signing
WEBHOOK_SECRET=

# --- Optional: Logging ---
# Set to "json" to enable JSON structured logging
# QA_LOG_FORMAT=json
