# =============================================================================
# Environment Variables — copy to .env and fill in values
# =============================================================================

# --- Required ---
ELEVENLABS_API_KEY=
OPENROUTER_API_KEY=

# --- Optional: Direct OpenAI fallback ---
OPENAI_API_KEY=

# --- Optional: RingCentral API (only for --date-from mode) ---
RC_APP_CLIENT_ID=
RC_APP_CLIENT_SECRET=
RC_SERVER_URL=https://platform.ringcentral.com
RC_USER_JWT=

# --- Optional: Webhook for Agent 4 results ---
WEBHOOK_URL=

# --- Optional: Logging ---
# Set to "json" to enable JSON structured logging
# QA_LOG_FORMAT=json
