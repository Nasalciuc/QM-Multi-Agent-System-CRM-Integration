# QM Multi-Agent System Configuration
# Copy this to .env and fill in your actual API keys

# OpenAI/OpenRouter LLM API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs Speech-to-Text API Key
# Get from: https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: OpenAI fallback (if using OpenAI instead of OpenRouter)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic Claude (alternative provider)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
