<body>

    <div class="page-loader"><div class="bg-primary"></div></div>

        <style>
        .login-wrapper {
            display: flex;
            min-height: 100vh;
            background: white;
            overflow: hidden;
        }

        .login-left-wrapper {
            flex: 1;
            position: relative;
            background: transparent;
            overflow: hidden;
        }

        .login-left {
            width: 100%;
            height: 100%;
            background-color: #7b96d4;
            display: flex;
            align-items: center;
            justify-content: center;

            /* Magia se întâmplă aici */
            clip-path: ellipse(100% 95% at 0% 50%);
        }

        .login-left img {
            max-width: 80%;
            height: auto;
        }

        .login-right {
            flex: 1;
            background-color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 40px;
            position: relative;
            /* AICI ADĂUGI */
        }

        .login-right .logo {
            max-height: 40px;
            margin-bottom: 30px;
            align-self: flex-end;
        }

        .login-form {
            max-width: 400px;
            width: 100%;
            margin: 0 auto;
        }

        .login-form h2 {
            font-size: 42px;
            font-weight: 600;
        }

        .login-form p {
            color: #444;
            margin-bottom: 30px;

        }

        .form-control {
            border: 1px solid #ccc;
            border-radius: 6px;
            height: 45px;
        }

        .btn-login {
            width: 100%;
            background-color: #4b65c1;
            color: #fff;
            border: none;
            height: 45px;
            border-radius: 6px;
            font-weight: 500;
        }

        .btn-login:hover {
            background-color: #3a53aa;
            color: white;
        }
    </style>

    <div class="login-wrapper">
        <div class="login-left-wrapper">
            <div class="login-left">
                <img src="/img/bg/auth/c.png" alt="Login illustration">
            </div>
        </div>

        <div class="login-right">
            <div style="position: absolute; top: 30px; right: 40px;">
                <img src="https://static-cdn.buybusinessclass.com/v/bbc/logo-dark.png"
                    style="height: 40px;">
            </div>

            <div class="login-form">
                <h2>System sign-in</h2>
                <p>Customer Relationship Management</p>

                <form id="login_form" method="POST" action="/login">
                    <input type="hidden" name="_token" value="puVc7rMfM0cFOrGo8dn9BZn1xWiV7wMBbyvvS7mE">                    <div class="form-group mb-3">
                        <label>Name</label>
                        <input type="text" class="form-control " name="name"
                            value="" required autofocus>
                                            </div>

                    <div class="form-group mb-4">
                        <label>Password</label>
                        <input type="password" class="form-control " name="password"
                            required>
                                            </div>

                    <button type="submit" class="btn btn-login">
                        Sign In
                        <span class="spinner spinner-border spinner-border-sm d-none ml-2" role="status"
                            aria-hidden="true"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>

        <script>
        $('#login_form').submit(function () {
            const btn = $(this).find('button[type=submit]');
            btn.prop('disabled', true);
            btn.find('.spinner').removeClass('d-none');
        });
    </script>
</body>
</html>
