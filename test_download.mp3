    <!-- Core stylesheets -->
    <link rel="stylesheet" href="/vendor/css/bootstrap.css?id=f25d1321d829d8c32c55">
    <link rel="stylesheet" href="/vendor/css/appwork.css?id=14bdc6d48894762d040f">
    <link rel="stylesheet" href="/vendor/css/theme-corporate.css?id=e1d74a6e9c1301e252e3">
    <link rel="stylesheet" href="/vendor/css/colors.css?id=1f88f16bf449d3fb5f29">
    <link rel="stylesheet" href="/vendor/css/uikit.css?id=98bd06bf35ac8e2c5d96">
